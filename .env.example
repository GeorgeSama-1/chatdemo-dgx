# Root-level defaults
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend model proxy settings
MODEL_BASE_URL=http://your-dgx-host:8000/v1
MODEL_API_KEY=your-api-key
MODEL_NAME=gpt-oss-chat
MODEL_ENABLE_THINKING=false
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
REQUEST_TIMEOUT=60

# Optional DGX desktop one-click model startup
MODEL_START_ENABLED=false
MODEL_CONDA_SH=
MODEL_CONDA_ENV=vllm
MODEL_START_COMMAND=
MODEL_HEALTH_URL=

# Frontend brand settings
NEXT_PUBLIC_PRODUCT_NAME=博微 智能助手
NEXT_PUBLIC_BRAND_NAME=BW Labs
NEXT_PUBLIC_BRAND_ACCENT=#0f4c81
NEXT_PUBLIC_MODEL_LABEL=gpt-oss-chat
